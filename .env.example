# Copy to .env and fill in. Ports match docker-compose.yml (non-default to avoid clashes).

# --- Postgres (the-agent-times-pg) ---
DATABASE_URL=postgresql://agenttimes:agenttimes@localhost:5433/agenttimes

# --- Redis (the-agent-times-redis) ---
REDIS_URL=redis://localhost:6380

# --- Anthropic / Claude Agent SDK ---
ANTHROPIC_API_KEY=

# --- ports (all in the 3010+ range; lower ports belong to other apps) ---
# web              3010
# chrome/server    3011
# agents           3012
CHROME_AGENT_PORT=3011
